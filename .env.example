# ─── Protocol ───────────────────────────────────────────
NEXT_PUBLIC_HTTP_PROTOCOLE=http
HTTP=http
WS=ws
ALLOWED_ORIGINS=http://localhost:3001

# ─── API server (contracts_backend) ─────────────────────
NEXT_PUBLIC_API_ROOT_URL=localhost
NEXT_PUBLIC_API_ROOT_PORT=8001
NEXT_PUBLIC_BACKEND_DOMAIN=localhost
NEXT_PUBLIC_BACKEND_API=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_DOMAIN_URL_PREFIX=http://localhost:3001
NEXT_PUBLIC_ROOT_API_URL=http://localhost:8001/api

# ─── NextAuth ───────────────────────────────────────────
NEXTAUTH_SECRET=CHANGE_ME_IN_PRODUCTION
NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# ─── Account endpoints ──────────────────────────────────
NEXT_PUBLIC_ACCOUNT_ROOT=http://localhost:8001/api/account
NEXT_PUBLIC_ACCOUNT_LOGIN=http://localhost:8001/api/account/login/
NEXT_PUBLIC_ACCOUNT_LOGOUT=http://localhost:8001/api/account/logout/
NEXT_PUBLIC_ACCOUNT_REFRESH_TOKEN=http://localhost:8001/api/account/token/refresh/
NEXT_PUBLIC_ACCOUNT_CREATE_ACCOUNT=http://localhost:8001/api/account/users/
NEXT_PUBLIC_ACCOUNT_CHECK_EMAIL=http://localhost:8001/api/account/check_email/
NEXT_PUBLIC_ACCOUNT_PASSWORD_CHANGE=http://localhost:8001/api/account/password_change/
NEXT_PUBLIC_ACCOUNT_SEND_PASSWORD_RESET=http://localhost:8001/api/account/send_password_reset/
NEXT_PUBLIC_ACCOUNT_PASSWORD_RESET=http://localhost:8001/api/account/password_reset/
NEXT_PUBLIC_ACCOUNT_PROFIL=http://localhost:8001/api/account/profil/
NEXT_PUBLIC_USERS_ROOT=http://localhost:8001/api/account/users/

# ─── Contract endpoints ──────────────────────────────────
NEXT_PUBLIC_CONTRACT_ROOT=http://localhost:8001/api/contract
NEXT_PUBLIC_CONTRACT_LIST=http://localhost:8001/api/contract/contracts/
NEXT_PUBLIC_CONTRACT_PDF=http://localhost:8001/api/contract/contracts/{id}/pdf/
NEXT_PUBLIC_CONTRACT_DOCX=http://localhost:8001/api/contract/contracts/{id}/docx/

# ─── Projets endpoints ──────────────────────────────────
NEXT_PUBLIC_PROJECT_ROOT=http://localhost:8001/api/projects
NEXT_PUBLIC_PROJECT_LIST=http://localhost:8001/api/projects/
NEXT_PUBLIC_COMPANY_CONFIG_LIST=http://localhost:8001/api/company-config/
